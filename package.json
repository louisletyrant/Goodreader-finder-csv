{
  "name": "obsidian-goodreads-csv-importer",
  "version": "1.0.0",
  "description": "Obsidian plugin to import the official Goodreads CSV export",
  "main": "main.js",
  "scripts": {
    "build": "tsc --noEmit && esbuild src/main.ts --bundle --external:obsidian --format=cjs --platform=browser --target=es2020 --outfile=main.js",
    "dev": "esbuild src/main.ts --bundle --external:obsidian --format=cjs --platform=browser --target=es2020 --outfile=main.js --watch"
  },
  "license": "MIT",
  "dependencies": {
    "papaparse": "^5.4.1"
  },
  "devDependencies": {
    "@types/papaparse": "^5.3.14",
    "@types/node": "^20.0.0",
    "esbuild": "^0.19.0",
    "obsidian": "^1.7.2",
    "typescript": "^5.4.0"
  }
}
